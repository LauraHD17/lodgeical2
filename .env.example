# Lodge-ical Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Frontend (VITE_ prefix = safe to expose in browser bundle) ───────────────

# Supabase project URL (found in Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe to expose — RLS enforces all access rules)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe publishable key (safe to expose — used only for Stripe.js on client)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ─── Edge Functions (Server-only — NEVER expose to the browser) ───────────────
# These are set via: supabase secrets set KEY=value
# They are NOT needed in .env for local development (auto-injected by Supabase)

# SUPABASE_SERVICE_ROLE_KEY   → Full DB access, bypasses RLS. Auto-injected.
# STRIPE_SECRET_KEY           → supabase secrets set STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET       → supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY              → supabase secrets set RESEND_API_KEY=re_...
